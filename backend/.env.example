# --- Railway production (копировать в Dashboard → Variables) ---
# NODE_ENV=production
# PORT=3001
# JWT_SECRET=erden_jwt_secret_key_2026_minimum32chars
# DATABASE_URL=postgresql://...neon.tech/...?sslmode=require
# FRONTEND_URL=https://erden-brand.vercel.app
# AUTO_MIGRATE=true   # при старте: npx sequelize-cli db:migrate (после подключения к БД)

# --- Сервер (локально) ---
NODE_ENV=development
PORT=3001

# --- JWT ---
JWT_SECRET=замени_на_секретный_ключ_минимум_32_символа
JWT_EXPIRES_IN=24h

# --- База: предпочтительно одна строка (Neon / Railway / локально) ---
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sewing_production
# Локальный Postgres без SSL — для localhost SSL в коде не включается.
# Удалённый хост без TLS: DATABASE_SSL=false

# --- Либо отдельные поля (если нет DATABASE_URL, строка соберётся автоматически) ---
# DB_HOST=your-host.neon.tech
# DB_PORT=5432
# DB_NAME=erden_db
# DB_USER=your_user
# DB_PASS=your_password
# DB_SSL=true

# Опционально: пул соединений Sequelize
# DB_POOL_MAX=5
# DB_POOL_MIN=0
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=10000

# --- CORS: URL фронтенда (Vercel), https:// без завершающего слеша ---
# Пример: https://erden-brand.vercel.app
FRONTEND_URL=

# --- Синхронизация в облако (опционально) ---
CLOUD_DATABASE_URL=
SYNC_TO_CLOUD=false
SYNC_INTERVAL_MS=30000

# --- Прочее ---
AUTO_SEED=true
