# URL backend API
# Development: см. также .env.development (localhost:3001 или пусто → Vite proxy).
# Production (Vercel): задайте VITE_API_URL в Project → Settings → Environment Variables.
# ВАЖНО: только https:// в production (иначе Mixed Content).
# Пример Railway: https://erdenbrand-production.up.railway.app
# Пример Render: https://erdenbrand.onrender.com
#
# Для доступа с телефона в локальной сети (dev):
# Оставьте пустым — Vite проксирует /api на backend.
# Откройте на телефоне: http://ВАШ_IP:5173 (например http://192.168.1.100:5173)
VITE_API_URL=

# Режим печати: bw (чёрно-белый, по умолчанию) | color (минимальный акцент)
# VITE_PRINT_THEME=bw
